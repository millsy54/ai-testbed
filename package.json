{
  "name": "vite-react-drag-files",
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:electron": "concurrently -k \"npm:dev:web\" \"npm:dev:electron:main\"",
    "dev:electron:main": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "build:web": "vite build",
    "build:electron": "npm run build:web && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.glen.dragfiles",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/files",
        "to": "files"
      }
    ]
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "wait-on": "^8.0.5"
  }
}
